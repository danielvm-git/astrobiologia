---
import LanguageSwitcher from "./LanguageSwitcher.tsx";

const locale = Astro.currentLocale ?? "pt-br";
const prefix = locale === "pt-br" ? "" : `/${locale}`;
---

<header class="sticky top-0 z-50 border-b border-slate-100 bg-white/95 backdrop-blur">
  <div class="mx-auto flex h-10 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href={`${prefix}/`} class="flex items-center gap-2">
      <svg class="h-6 w-6 text-slate-900" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6"/><path d="M8 11h6"/>
      </svg>
      <span class="text-sm font-black uppercase tracking-widest">Astrobiologia</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      <a href={`${prefix}/`} class="text-xs font-black uppercase tracking-widest text-slate-500 hover:text-slate-900 transition-colors">
        Início
      </a>
      <a href={`${prefix}/artigos`} class="text-xs font-black uppercase tracking-widest text-slate-500 hover:text-slate-900 transition-colors">
        Artigos
      </a>
      <a href={`${prefix}/sobre`} class="text-xs font-black uppercase tracking-widest text-slate-500 hover:text-slate-900 transition-colors">
        Sobre
      </a>
      <a href="/admin" class="text-xs font-black uppercase tracking-widest text-slate-500 hover:text-slate-900 transition-colors">
        Admin
      </a>
      <LanguageSwitcher client:load currentLocale={locale} />
    </nav>

    <button id="mobile-toggle" class="md:hidden p-1" aria-label="Abrir menu">
      <svg id="icon-menu" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" class="h-5 w-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-slate-100 px-4 py-4 md:hidden">
    <div class="flex flex-col gap-4">
      <a href={`${prefix}/`} class="text-xs font-black uppercase tracking-widest text-slate-600">Início</a>
      <a href={`${prefix}/artigos`} class="text-xs font-black uppercase tracking-widest text-slate-600">Artigos</a>
      <a href={`${prefix}/sobre`} class="text-xs font-black uppercase tracking-widest text-slate-600">Sobre</a>
      <a href="/admin" class="text-xs font-black uppercase tracking-widest text-slate-600">Admin</a>
      <div class="pt-2 border-t border-slate-100 flex flex-wrap gap-3">
        {["pt-br", "en", "es", "ja", "nl", "zh"].map((l) => (
          <a
            href={l === "pt-br" ? "/" : `/${l}/`}
            class={`text-[10px] font-black uppercase tracking-widest ${l === locale ? "text-slate-900" : "text-slate-400 hover:text-slate-600"}`}
          >
            {l.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    iconMenu?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
  });
</script>
