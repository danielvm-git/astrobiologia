---
import Public from "../../layouts/Public.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getFeaturedArticles, getPublishedArticles } from "../../lib/article-read";

const locale = Astro.currentLocale ?? "pt-br";
const prefix = locale === "pt-br" ? "" : `/${locale}`;

let featured: Awaited<ReturnType<typeof getFeaturedArticles>> = [];
let recent: Awaited<ReturnType<typeof getPublishedArticles>> = [];

try {
  [featured, recent] = await Promise.all([
    getFeaturedArticles(locale, 6),
    getPublishedArticles(locale, 24),
  ]);
} catch (err) {
  console.error("INDEX ARTICLE FETCH ERROR:", err);
  // Show empty state instead of 500
}

const hero = featured[0];
const sidebarArticles = recent.slice(0, 5);
---

<Public title="Astrobiologia — Portal Científico Brasileiro">
  <!-- Page hero shell -->
  <header class="bg-slate-900 -mx-4 px-4 py-8 mb-12 text-center sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8">
    <h1 class="text-3xl md:text-5xl font-black tracking-tight text-white leading-tight">
      Explorando a Vida no Universo<span class="text-slate-400">.</span>
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg italic leading-relaxed text-slate-400 font-serif">
      Jornalismo científico sobre astrobiologia, exoplanetas e a busca por vida além da Terra.
    </p>
  </header>

  <!-- Hero + sidebar layout -->
  {hero && (
    <section class="mb-16">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-12 md:gap-10">
        <div class="md:col-span-7">
          <ArticleCard article={hero} locale={locale} variant="featured" />
        </div>
        <aside class="md:col-span-5">
          <h2 class="mb-4 text-xs font-black uppercase tracking-[0.2em] text-slate-400">
            Últimas Reportagens
          </h2>
          <div class="divide-y divide-slate-100">
            {sidebarArticles.map((article) => (
              <ArticleCard article={article} locale={locale} variant="compact" />
            ))}
          </div>
        </aside>
      </div>
    </section>
  )}

  <!-- Recent articles grid -->
  <section>
    <h2 class="text-2xl font-black uppercase tracking-tight text-slate-900 mb-8">
      Artigos Recentes
    </h2>
    {recent.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recent.map((article) => (
          <ArticleCard article={article} locale={locale} />
        ))}
      </div>
    ) : (
      <p data-testid="empty-state" class="text-slate-400 italic text-center py-16">
        Nenhum artigo publicado ainda.
      </p>
    )}
    <div class="text-center mt-10">
      <a
        href={`${prefix}/artigos`}
        class="inline-block px-8 py-3 border-2 border-slate-900 text-slate-900 font-black uppercase tracking-widest text-xs rounded-xl hover:bg-slate-900 hover:text-white transition-all"
      >
        Ver Todos os Artigos
      </a>
    </div>
  </section>
</Public>
