{
  "name": "@astrobiologia/web-nuxt",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "check": "nuxt typecheck",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "npm run test:e2e:p0",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:api": "playwright test --project=api",
    "test:e2e": "playwright test --project=chromium --config=playwright.config.ts",
    "test:e2e:p0": "playwright test tests/e2e/p0 --project=chromium --config=playwright.config.ts",
    "test:e2e:p1": "playwright test tests/e2e/p1 --project=chromium --config=playwright.config.ts",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e:p0 && npm run test:e2e:p1",
    "lint": "prettier --check {pages,components,server,lib,i18n.config.ts,middleware,layouts,error.vue} --ignore-unknown 2>/dev/null || true"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.3.0",
    "@pinia/nuxt": "^0.11.3",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "appwrite": "^24.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-vue-next": "^1.0.0",
    "node-appwrite": "^24.0.0",
    "nuxt": "3.21.2",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "shadcn-vue": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.8",
    "happy-dom": "^16.8.1",
    "vitest": "^3.2.4"
  }
}
