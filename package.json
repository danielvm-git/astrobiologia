{
  "name": "astrobiologia-monorepo",
  "private": true,
  "workspaces": [
    "apps/web-nuxt"
  ],
  "scripts": {
    "prepare": "husky",
    "preflight": "npm run check && npm run test && npx lint-staged --diff HEAD",
    "dev": "npm run dev -w @astrobiologia/web-nuxt",
    "build": "npm run build -w @astrobiologia/web-nuxt",
    "test": "npm run test -w @astrobiologia/web-nuxt",
    "check": "npm run check -w @astrobiologia/web-nuxt"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@astrobiologia/web-nuxt": "*",
    "appwrite": "^24.2.0",
    "node-appwrite": "^24.0.0"
  }
}
