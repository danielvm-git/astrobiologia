{
  "name": "astrobiologia-monorepo",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "husky",
    "type-check": "pnpm --filter @astrobiologia/web-astro check",
    "lint": "pnpm --filter @astrobiologia/web-astro lint",
    "preflight": "pnpm type-check && pnpm lint && pnpm test:unit && pnpm build && pnpm test:e2e && pnpm exec lint-staged --diff HEAD",
    "dev": "pnpm --filter @astrobiologia/web-astro dev",
    "build": "pnpm --filter @astrobiologia/web-astro build",
    "generate": "pnpm --filter @astrobiologia/web-astro build",
    "test": "pnpm --filter @astrobiologia/web-astro test:unit",
    "test:unit": "pnpm --filter @astrobiologia/web-astro test:unit",
    "test:e2e": "pnpm --filter @astrobiologia/web-astro test:e2e",
    "test:all": "pnpm test:unit && pnpm build && pnpm test:e2e",
    "test:fast": "pnpm --filter @astrobiologia/web-astro test:unit",
    "test:coverage": "pnpm --filter @astrobiologia/web-astro test:coverage",
    "report:astro:watch": "pnpm --filter @astrobiologia/web-astro report:watch",
    "check": "pnpm --filter @astrobiologia/web-astro check"
  },
  "devDependencies": {
    "@ctxo/cli": "^0.8.1",
    "@ctxo/lang-typescript": "^0.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "appwrite": "^24.2.0",
    "node-appwrite": "^24.0.0"
  }
}
